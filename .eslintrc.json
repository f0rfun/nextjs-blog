{
    "env": {
        "browser": true,
        "es2021": true
    },
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 13,
        "sourceType": "module"
    },
    "plugins": [
        "react"
    ],
    "rules": {
    },
    "settings":{
        "react": {
            "version": "latest"
        }
    },
    "extends": [
        "plugin:react/recommended",
        "google",
        "prettier"
    ]
}

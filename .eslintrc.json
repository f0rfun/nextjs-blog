{
    "env": {
        "es6": true,
        "jest": true
    },
    "parser": "@typescript-eslint/parser",
    "extends": [
        "standard",
        "eslint-config-prettier",
        "plugin:prettier/recommended",
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "prettier"
    ],
    "plugins": [
        "@typescript-eslint",
        "prettier"
    ],
    "parserOptions": {
        "ecmaVersion": 9,
        "sourceType": "module"
    },
    "rules": {
        "prettier/prettier": [
            "error",
            {
                "trailingComma": "none"
            }
        ]
    }
}
